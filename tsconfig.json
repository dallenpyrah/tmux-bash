{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "types": ["bun", "node"],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src", ".opencode/tools", "test"]
}
